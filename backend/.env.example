# Copy to .env and fill in real values. .env is gitignored.

# MySQL connection
DATABASE_URL=mysql+pymysql://root:CHANGE_ME@localhost:3306/bytesdoc

# JWT - generate a long random string for production
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# CORS - origins allowed to call this API (Next.js dev server)
CORS_ORIGINS=http://localhost:3000
